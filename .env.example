# AzlanAI Environment Variables

MONGODB_URI=mongodb+srv://your-user:your-password@cluster.mongodb.net/azlanai
JWT_SECRET=your-super-secret-jwt-key

# Stripe (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
CLIENT_URL=http://localhost:5000

# Email (Gmail: use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="AzlanAI <your-email@gmail.com>"

# AI Chat (optional — uses smart rules if not set)
OPENAI_API_KEY=sk-your-openai-key

PORT=5000
